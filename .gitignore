# Secrets — never commit (see CLAUDE.md §5 and host secrets standard)
.env
.env.*
*.secret
*.pem
*.key
secrets/

# Synthetic/scratch data — keep raw transaction/trade/comms data out of the repo
data/
*.csv
*.parquet

# Generated deliverables (engagement briefs, BRDs, FSDs, review reports, audit packs).
# Authored as .md and rendered to .html; may contain engagement specifics — keep out of git.
artifacts/

# Code-execution consent marker (per-engagement; never commit — it's a local authorisation)
.claude/.exec-consent

# Cached tool-availability probe (environment-specific; regenerated by check-review-tools.sh)
.claude/.tool-availability

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# One-time guard-hardening maintenance run (ADR-002 recs 10-13) + its backups - not committed
apply-guard-hardening.sh
.guard-hardening-backup-*/

# One-time guard-fix maintenance run (ADR-002 rec 14) - same rationale; its backup dir
# (.guard-hardening-backup-fixes-*/) is covered by the glob above
apply-guard-fixes.sh

# One-shot wrapper for the human-only steps of the 2026-07-05 audit fix pass
human-steps.sh
docs/executive-brief-draft.html
