{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "findings-schema",
  "title": "Compliance-surveillance team - review findings pack",
  "description": "The structured source of truth for a review/audit report. scripts/render_findings.py renders it to the canonical REVIEW-<slug>.md; scripts/validate_findings.py enforces this schema. The model supplies field VALUES; the renderer owns the FORMAT - so a finding can never drift (5C/C-word/inline). Narrative sections are string fields so the whole report renders from one pack.",
  "type": "object",
  "required": ["slug", "scope", "mode", "verdict", "findings"],
  "additionalProperties": true,
  "properties": {
    "slug": { "type": "string", "description": "kebab-case id; drives the artifact filename" },
    "kind": {
      "type": "string",
      "enum": ["review", "security-audit", "performance"],
      "description": "which review kind - drives the rendered artifact's prefix (REVIEW- / SECURITY-AUDIT- / PERF-) and title. Defaults to 'review' if omitted."
    },
    "title": { "type": "string" },
    "scope": { "type": "string", "description": "files / commit range reviewed" },
    "commit": { "type": "string", "description": "the reviewed commit SHA, if known" },
    "mode": { "type": "string", "enum": ["change", "audit"] },
    "reviewer_independence": { "type": "string" },
    "tooling_coverage": { "type": "string", "description": "analysers run / skipped (🔬)" },
    "verdict": { "type": "string", "description": "free-text verdict; wording varies by kind (e.g. 'conditional', 'audit-ready', 'scales to target', 'won't scale')" },
    "executive_summary": { "type": "string" },
    "developer_guidance": { "type": "string", "description": "the mandatory 🔵 forward-looking section" },
    "limitations": { "type": "string", "description": "limitations & residual risk" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "title", "severity", "location", "basis",
          "standard", "problem", "likely_cause", "impact", "fix", "disposition"
        ],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "warning", "medium", "style"] },
          "location": { "type": "string", "description": "file:line" },
          "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
          "basis": { "type": "string", "enum": ["measured", "coded", "inferred"] },
          "standard": { "type": "string", "description": "the cited rule / CWE / § (audit 'criteria')" },
          "problem": { "type": "string", "description": "what is wrong + how we know (audit 'condition')" },
          "likely_cause": { "type": "string", "description": "why the gap exists; never silent (audit 'cause')" },
          "impact": { "type": "string", "description": "consequence in domain terms (audit 'consequence')" },
          "impact_basis": { "type": "string", "enum": ["measured", "coded", "inferred"] },
          "current_cost": { "type": "string", "description": "performance only: the current cost (e.g. '4.2s @ 100k rows')" },
          "projected_cost": { "type": "string", "description": "performance only: cost after the fix" },
          "gain": { "type": "string", "description": "performance only: the improvement (e.g. '~40x @ 100k')" },
          "fix": {
            "type": "object",
            "required": ["diff", "why"],
            "additionalProperties": true,
            "properties": {
              "diff": { "type": "string", "description": "the diff-style fix (audit 'corrective action')" },
              "why": { "type": "string", "description": "why this fix works" }
            }
          },
          "disposition": { "type": "string", "enum": ["open", "fixed", "accepted", "deferred"] }
        }
      }
    }
  }
}
