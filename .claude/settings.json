{
  "permissions": {
    "allow": [
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(python -m scripts.gen_synthetic:*)",
      "Bash(python3 -m scripts.gen_synthetic:*)",
      "Bash(python -m scripts.ingest:*)",
      "Bash(python -m scripts.validate_masking:*)",
      "Bash(python3 -m scripts.validate_masking:*)",
      "Bash(pre-commit run:*)",
      "Bash(git diff:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(mypy:*)",
      "Bash(bandit:*)",
      "Bash(pip-audit:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(bashate:*)",
      "Bash(semgrep:*)",
      "Bash(gitleaks:*)",
      "Bash(checkstyle:*)",
      "Bash(pmd:*)",
      "Bash(spotbugs:*)",
      "Bash(scalafmt:*)",
      "Bash(scalafix:*)",
      "Bash(pwsh -Command Invoke-ScriptAnalyzer:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-raw-data.py\""
          }
        ]
      }
    ]
  }
}
