{
  "permissions": {
    "deny": [
      "Read(./data/raw/**)",
      "Read(data/raw/**)",
      "Read(/*/data/raw/**)",
      "Read(/**/data/raw/**)",
      "Grep(./data/raw/**)",
      "Grep(data/raw/**)",
      "Grep(/*/data/raw/**)",
      "Grep(/**/data/raw/**)",
      "Glob(./data/raw/**)",
      "Glob(data/raw/**)",
      "Glob(/*/data/raw/**)",
      "Glob(/**/data/raw/**)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(.env)",
      "Read(/**/.env)",
      "Read(/**/.env.*)",
      "Read(./secrets/**)",
      "Read(secrets/**)",
      "Read(/**/secrets/**)",
      "Read(./**/*.pem)",
      "Read(/**/*.pem)",
      "Read(./**/*.key)",
      "Read(/**/*.key)"
    ],
    "allow": [
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(python -m scripts.gen_synthetic:*)",
      "Bash(python3 -m scripts.gen_synthetic:*)",
      "Bash(python -m scripts.ingest:*)",
      "Bash(python -m scripts.validate_masking:*)",
      "Bash(python3 -m scripts.validate_masking:*)",
      "Bash(pre-commit run:*)",
      "Bash(git diff:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(mypy:*)",
      "Bash(bandit:*)",
      "Bash(pip-audit:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(bashate:*)",
      "Bash(semgrep:*)",
      "Bash(gitleaks:*)",
      "Bash(checkstyle:*)",
      "Bash(pmd:*)",
      "Bash(spotbugs:*)",
      "Bash(scalafmt:*)",
      "Bash(scalafix:*)",
      "Bash(pwsh -Command Invoke-ScriptAnalyzer:*)",
      "Bash(python -m scripts.render_html:*)",
      "Bash(python3 -m scripts.render_html:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT:-${CLAUDE_PROJECT_DIR:-.}}/.claude/hooks/run-guard.sh\" \"${CLAUDE_PLUGIN_ROOT:-${CLAUDE_PROJECT_DIR:-.}}/.claude/hooks/guard-raw-data.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT:-${CLAUDE_PROJECT_DIR:-.}}/.claude/hooks/run-guard.sh\" \"${CLAUDE_PLUGIN_ROOT:-${CLAUDE_PROJECT_DIR:-.}}/.claude/hooks/guard-code-execution.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT:-${CLAUDE_PROJECT_DIR:-.}}/.claude/hooks/run-guard.sh\" \"${CLAUDE_PLUGIN_ROOT:-${CLAUDE_PROJECT_DIR:-.}}/.claude/hooks/guard-consent-writes.py\""
          }
        ]
      }
    ]
  }
}
